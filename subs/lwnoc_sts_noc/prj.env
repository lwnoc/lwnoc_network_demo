#!/bin/bash

script_directory="$(dirname "${BASH_SOURCE[0]}")"

absolute_path=$(readlink -f "$script_directory")

echo "set RTL_PATH: $absolute_path"

module load vcs
module load spyglass
module load verdi
module load synopsys_lic/ver1
# module load fde
# module load syn/T-2022.03-SP2

export RTL_PATH=$absolute_path
export STS_INIU=$absolute_path
export STS_TNIU=$absolute_path

export COMMON_IP_PATH=$RTL_PATH/fcip
export FCIP_DIR=$RTL_PATH/fcip